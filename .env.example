NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

FM_RUNTIME_DIR=/app/.runtime
FM_UPLOAD_DIR=/app/.runtime/uploads
FM_SQLITE_PATH=/app/.runtime/app.sqlite3
FM_KNOWLEDGE_ROOT=/app/knowledge
FM_RAG_ENABLED=1
FM_RAG_INDEX_DIR=/app/backend/app/data/rag_index
FM_RAG_MODEL_PATH=/models/bge-m3
# Optional: use the configured LLM to naturalize already-filtered RAG snippets
# into customer-facing report sections. Disable to force deterministic local fusion.
FM_RAG_LLM_FUSION_ENABLED=1
# Host-side model directory for Docker Compose. Keep this outside the Git repo.
FM_RAG_MODEL_HOST_DIR=C:/RAG/models/bge-m3
FM_RAG_LOCAL_FILES_ONLY=1
HF_HOME=/app/.cache/huggingface
SENTENCE_TRANSFORMERS_HOME=/app/.cache/huggingface
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Optional: only set this if you provide a local reference PDF outside Git.
# FM_REPORT_REFERENCE_PATH=/app/report-reference.pdf

# Optional LLM config. The same model config is used for report composition
# and for image-based OCR when users upload PNG/JPG scans.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_API_STYLE=auto
LLM_TIMEOUT_SECONDS=90
LLM_TEMPERATURE=0.1
# Keep original draft/report generation rule-based by default.
# The LLM may still be used by the RAG fusion layer above.
FM_LLM_DRAFT_COMPOSER_ENABLED=0
